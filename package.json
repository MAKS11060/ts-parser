{
  "private": true,
  "version": "0.0.0",
  "name": "@maks11060/ts-parser",
  "type": "module",
  "author": {
    "name": "maks11060"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node --run ok && tsdown",
    "fmt": "dprint fmt",
    "ok": "dprint check",
    "prepare": "git config core.hooksPath .hooks"
  },
  "imports": {
    "#lib/*": "./src/lib/*"
  },
  "exports": {
    ".": {
      "import": "./dist/mod.mjs",
      "types": "./dist/mod.d.mts"
    },
    "./rezka": {
      "import": "./dist/rezka/mod.mjs",
      "types": "./dist/rezka/mod.d.mts"
    }
  },
  "dependencies": {
    "@b-fuze/deno-dom": "jsr:^0.1.56",
    "@maks11060/web": "jsr:^0.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260214.1",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  },
  "devEngines": {
    "packageManager": { "name": "pnpm" }
  }
}
