{
  "editor.defaultFormatter": "dprint.dprint",

  "js/ts.referencesCodeLens.enabled": true,

  "explorer.fileNesting.patterns": {
    "package.json": ".*, *.config.ts, *.config.js, tsconfig.json, dprint.*, pnpm-*"
  },

  "nodejs-testing.env": { "FORCE_COLOR": "0" },
  "nodejs-testing.extensions": [{
    "filePatterns": ["**/*{js,ts}"],
    "parameters": ["--env-file-if-exists=.env", "--import", "tsx"],
    "extensions": ["ts"]
  }]
}
